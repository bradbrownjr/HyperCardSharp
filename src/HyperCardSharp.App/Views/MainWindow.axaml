<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="660" Height="460"
        MinWidth="400" MinHeight="300"
        CanResize="True"
        Background="#333333">

    <DockPanel>
        <!-- Status bar at bottom -->
        <Border DockPanel.Dock="Bottom" Background="#222222" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="#CCCCCC"
                           FontSize="12"
                           FontFamily="Consolas, Courier New, monospace"
                           Padding="8,4"
                           VerticalAlignment="Center"/>
                <!-- System 7-style help button, bottom-right -->
                <Button x:Name="HelpButton"
                        Grid.Column="1"
                        Content="?"
                        Width="22" Height="22"
                        Margin="4,3,4,3"
                        Click="OnHelpClick"
                        Background="#CCCCCC" Foreground="#000000"
                        BorderBrush="#000000" BorderThickness="1"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        FontFamily="Geneva, Helvetica, Arial, sans-serif"
                        FontWeight="Bold" FontSize="12" Padding="0"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Keyboard Shortcuts (Ctrl+H)"/>
            </Grid>
        </Border>

        <!-- Card display area — content auto-scales to fit -->
        <controls:SkiaBitmapControl x:Name="CardDisplay"
                                     Source="{Binding CurrentBitmap}"
                                     Margin="4"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"/>
    </DockPanel>
</Window>
