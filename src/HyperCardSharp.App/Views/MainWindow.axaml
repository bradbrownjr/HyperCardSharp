<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="660" Height="460"
        MinWidth="400" MinHeight="300"
        CanResize="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <!-- Outer border with rounded top corners — required for transparent-window chrome -->
    <Border BorderBrush="#000000" BorderThickness="1"
            CornerRadius="8,8,0,0" ClipToBounds="False"
            Background="#C0C0C0">
        <DockPanel>

            <!-- Menu bar: topmost element, white bg, Chicago font.
                 Doubles as drag handle — PointerPressed wired in code-behind. -->
            <!-- Custom System 7 menu bar with Apple logo and proper click handling -->
            <controls:System7MenuBar x:Name="MenuBar"
                                     DockPanel.Dock="Top"/>

            <!-- Card display area — content fills remaining space -->
            <controls:SkiaBitmapControl x:Name="CardDisplay"
                                         Source="{Binding CurrentBitmap}"
                                         Margin="0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"/>
        </DockPanel>
    </Border>
</Window>
