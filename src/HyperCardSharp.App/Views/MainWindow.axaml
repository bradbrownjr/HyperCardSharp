<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="660" Height="460"
        MinWidth="400" MinHeight="300"
        CanResize="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <!-- Outer border with rounded top corners — required for transparent-window chrome -->
    <Border BorderBrush="#000000" BorderThickness="1"
            CornerRadius="8,8,0,0" ClipToBounds="True"
            Background="#C0C0C0">
        <DockPanel>

            <!-- Menu bar: topmost element, white bg, Chicago font.
                 Doubles as drag handle — PointerPressed wired in code-behind. -->
            <Border x:Name="MenuBarBorder"
                    DockPanel.Dock="Top"
                    Background="#FFFFFF"
                    CornerRadius="7,7,0,0"
                    BorderBrush="#000000"
                    BorderThickness="0,0,0,1"
                    Padding="0">
                <Menu Background="Transparent"
                      Foreground="#000000"
                      FontFamily="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"
                      FontSize="13"
                      FontWeight="Bold"
                      Padding="6,2,6,2">
                    <MenuItem>
                        <MenuItem.Header>
                            <Image Source="avares://HyperCardSharp.App/Assets/apple-logo.png"
                                   Width="14" Height="14"/>
                        </MenuItem.Header>
                        <MenuItem Header="About HyperCard#…"
                                  Click="OnMenuAbout"/>
                    </MenuItem>
                    <MenuItem Header="File">
                        <MenuItem Header="Open…"
                                  InputGesture="Ctrl+O"
                                  Click="OnMenuOpen"/>
                        <MenuItem Header="Switch Stack…"
                                  InputGesture="Ctrl+M"
                                  Click="OnMenuSwitchStack"/>
                        <Separator/>
                        <MenuItem Header="Quit"
                                  InputGesture="Ctrl+Q"
                                  Click="OnMenuQuit"/>
                    </MenuItem>
                    <MenuItem Header="View">
                        <MenuItem Header="{Binding RenderModeLabel}"
                                  Click="OnMenuToggleRenderMode"/>
                        <Separator/>
                        <MenuItem Header="Zoom 1×"  InputGesture="Ctrl+1"  Click="OnMenuZoom1"/>
                        <MenuItem Header="Zoom 2×"  InputGesture="Ctrl+2"  Click="OnMenuZoom2"/>
                        <MenuItem Header="Zoom 3×"  InputGesture="Ctrl+3"  Click="OnMenuZoom3"/>
                        <MenuItem Header="Zoom 4×"  InputGesture="Ctrl+4"  Click="OnMenuZoom4"/>
                    </MenuItem>
                    <MenuItem Header="Help">
                        <MenuItem Header="Keyboard Shortcuts…"
                                  InputGesture="Ctrl+H"
                                  Click="OnMenuHelp"/>
                    </MenuItem>
                </Menu>
            </Border>

            <!-- Card display area — content fills remaining space -->
            <controls:SkiaBitmapControl x:Name="CardDisplay"
                                         Source="{Binding CurrentBitmap}"
                                         Margin="0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"/>
        </DockPanel>
    </Border>
</Window>
