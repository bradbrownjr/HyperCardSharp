<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="660" Height="460"
        MinWidth="400" MinHeight="300"
        CanResize="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <!-- System 7 window: 1px black border, rounded top corners, white background.
         Popup dropdowns render in their own top-level window. -->
    <Border BorderBrush="#000000" BorderThickness="1"
            CornerRadius="8" ClipToBounds="True"
            Background="#FFFFFF">
        <DockPanel>

            <!-- Menu bar: Chicago font, Apple logo, dropdowns. -->
            <controls:System7MenuBar x:Name="MenuBar"
                                     DockPanel.Dock="Top"/>

            <!-- Bottom row: grow box sits at bottom-right -->
            <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,16" Height="16">
                <!-- Bottom border area under card (left of grow box) -->
                <Border Grid.Column="0" Background="#FFFFFF"
                        BorderBrush="#000000" BorderThickness="0,1,0,0"/>
                <!-- Grow box: classic Mac resize handle -->
                <controls:System7GrowBox Grid.Column="1" x:Name="GrowBox"/>
            </Grid>

            <!-- Main content: card + scrollbar side by side -->
            <Grid ColumnDefinitions="*,16">
                <!-- Card display area -->
                <controls:SkiaBitmapControl Grid.Column="0"
                                             x:Name="CardDisplay"
                                             Source="{Binding CurrentBitmap}"
                                             Margin="0"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"/>

                <!-- Authentic System 7 scrollbar (decorative — HyperCard
                     stacks are fixed-size so there's nothing to scroll,
                     but the scrollbar is always present visually). -->
                <controls:System7ScrollBar Grid.Column="1"
                                            x:Name="CardScrollBar"/>
            </Grid>
        </DockPanel>
    </Border>
</Window>
