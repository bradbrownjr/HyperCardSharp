<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="660" Height="460"
        MinWidth="400" MinHeight="300"
        CanResize="True"
        SystemDecorations="None"
        Background="#C0C0C0">

    <!-- 1px black outer border — System 7 window outline -->
    <Border BorderBrush="#000000" BorderThickness="1" Background="#C0C0C0">
        <DockPanel>

            <!-- System 7.5 striped title bar (drag + close box) -->
            <controls:System7TitleBar x:Name="TitleBar"
                                      DockPanel.Dock="Top"
                                      Title="{Binding Title}"
                                      CloseRequested="OnTitleBarClose"/>

            <!-- Hairline rule under title bar -->
            <Border DockPanel.Dock="Top" Height="1" Background="#000000"/>

            <!-- Mac System 7 menu bar: white background, Chicago font, 1px black bottom border -->
            <Border DockPanel.Dock="Top"
                    Background="#FFFFFF"
                    BorderBrush="#000000"
                    BorderThickness="0,0,0,1"
                    Padding="0">
                <Menu Background="Transparent"
                      Foreground="#000000"
                      FontFamily="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"
                      FontSize="13"
                      Padding="4,2">
                    <MenuItem Header="&#x2318;" FontSize="14">
                        <MenuItem Header="About HyperCard#…"
                                  Click="OnMenuAbout"/>
                    </MenuItem>
                    <MenuItem Header="File">
                        <MenuItem Header="Open…"
                                  InputGesture="Ctrl+O"
                                  Click="OnMenuOpen"/>
                        <MenuItem Header="Switch Stack…"
                                  InputGesture="Ctrl+M"
                                  Click="OnMenuSwitchStack"/>
                    </MenuItem>
                    <MenuItem Header="View">
                        <MenuItem Header="{Binding RenderModeLabel}"
                                  Click="OnMenuToggleRenderMode"/>
                        <Separator/>
                        <MenuItem Header="Zoom 1×"  InputGesture="Ctrl+1"  Click="OnMenuZoom1"/>
                        <MenuItem Header="Zoom 2×"  InputGesture="Ctrl+2"  Click="OnMenuZoom2"/>
                        <MenuItem Header="Zoom 3×"  InputGesture="Ctrl+3"  Click="OnMenuZoom3"/>
                        <MenuItem Header="Zoom 4×"  InputGesture="Ctrl+4"  Click="OnMenuZoom4"/>
                    </MenuItem>
                    <MenuItem Header="Help">
                        <MenuItem Header="Keyboard Shortcuts…"
                                  InputGesture="Ctrl+H"
                                  Click="OnMenuHelp"/>
                    </MenuItem>
                </Menu>
            </Border>

            <!-- Card display area — content fills remaining space -->
            <controls:SkiaBitmapControl x:Name="CardDisplay"
                                         Source="{Binding CurrentBitmap}"
                                         Margin="0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"/>
        </DockPanel>
    </Border>
</Window>
