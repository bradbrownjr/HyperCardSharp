<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="660" Height="460"
        MinWidth="400" MinHeight="300"
        CanResize="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <!-- System 7 window: 1px black border, rounded top corners, white background.
         Popup dropdowns render in their own top-level window. -->
    <Border BorderBrush="#000000" BorderThickness="1"
            CornerRadius="8" ClipToBounds="True"
            Background="#FFFFFF">
        <DockPanel>

            <!-- System 7 title bar: horizontal stripes, close box, and window title.
                 Handles window drag and close. ColorMode set in code-behind. -->
            <controls:System7TitleBar x:Name="TitleBar"
                                      DockPanel.Dock="Top"
                                      Title="{Binding Title}"
                                      CloseRequested="OnTitleBarClose"/>

            <!-- Menu bar: Chicago font, Apple logo, dropdowns. -->
            <controls:System7MenuBar x:Name="MenuBar"
                                     DockPanel.Dock="Top"/>

            <!-- Card display area — content fills remaining space -->
            <controls:SkiaBitmapControl x:Name="CardDisplay"
                                         Source="{Binding CurrentBitmap}"
                                         Margin="0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"/>
        </DockPanel>
    </Border>
</Window>
