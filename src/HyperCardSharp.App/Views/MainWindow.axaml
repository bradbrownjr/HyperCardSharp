<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="660" Height="460"
        MinWidth="400" MinHeight="300"
        CanResize="True"
        Background="#333333">

    <DockPanel>
        <!-- Mac System 7 menu bar: white background, Chicago font, 1px black bottom border -->
        <Border DockPanel.Dock="Top"
                Background="#FFFFFF"
                BorderBrush="#000000"
                BorderThickness="0,0,0,1">
            <Menu Background="Transparent"
                  FontFamily="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"
                  FontSize="13"
                  Padding="4,0">
                <!-- Apple menu symbol -->
                <MenuItem Header="&#xF8FF;" FontSize="14">
                    <MenuItem Header="About HyperCard#…"
                              Click="OnMenuAbout"/>
                </MenuItem>
                <MenuItem Header="_File">
                    <MenuItem Header="_Open…"
                              InputGesture="Ctrl+O"
                              Click="OnMenuOpen"/>
                    <MenuItem Header="_Switch Stack…"
                              InputGesture="Ctrl+M"
                              Click="OnMenuSwitchStack"/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="{Binding RenderModeLabel}"
                              Click="OnMenuToggleRenderMode"/>
                    <Separator/>
                    <MenuItem Header="Zoom _1×"  InputGesture="Ctrl+1"  Click="OnMenuZoom1"/>
                    <MenuItem Header="Zoom _2×"  InputGesture="Ctrl+2"  Click="OnMenuZoom2"/>
                    <MenuItem Header="Zoom _3×"  InputGesture="Ctrl+3"  Click="OnMenuZoom3"/>
                    <MenuItem Header="Zoom _4×"  InputGesture="Ctrl+4"  Click="OnMenuZoom4"/>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="Keyboard Shortcuts…"
                              InputGesture="Ctrl+H"
                              Click="OnMenuHelp"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- Status bar at bottom -->
        <Border DockPanel.Dock="Bottom" Background="#222222" Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="#CCCCCC"
                           FontSize="12"
                           FontFamily="Consolas, Courier New, monospace"
                           Padding="8,4"
                           VerticalAlignment="Center"/>
                <!-- System 7-style help button, bottom-right -->
                <Button x:Name="HelpButton"
                        Grid.Column="1"
                        Content="?"
                        Width="22" Height="22"
                        Margin="4,3,4,3"
                        Click="OnHelpClick"
                        Background="#CCCCCC" Foreground="#000000"
                        BorderBrush="#000000" BorderThickness="1"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        FontFamily="Geneva, Helvetica, Arial, sans-serif"
                        FontWeight="Bold" FontSize="12" Padding="0"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Keyboard Shortcuts (Ctrl+H)"/>
            </Grid>
        </Border>

        <!-- Card display area — content auto-scales to fit -->
        <controls:SkiaBitmapControl x:Name="CardDisplay"
                                     Source="{Binding CurrentBitmap}"
                                     Margin="4"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"/>
    </DockPanel>
</Window>
