<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.StackPickerWindow"
        Title="Select a Stack"
        Width="520" Height="380"
        MinWidth="420" MinHeight="280"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"
        FontSize="12">

    <!-- System 7 window: 1px black outline, white background -->
    <Border BorderBrush="#000000" BorderThickness="1" Background="#FFFFFF">
        <DockPanel>

            <!-- Striped title bar -->
            <controls:System7TitleBar x:Name="TitleBar"
                                      DockPanel.Dock="Top"
                                      Title="Select a Stack"
                                      CloseRequested="OnTitleBarClose"/>

            <!-- Hairline rule under title bar -->
            <Border DockPanel.Dock="Top" Height="1" Background="#000000"/>

            <!-- Content area -->
            <DockPanel Margin="10,8,10,10">

                <!-- Info line + buttons across the top -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock x:Name="InfoText" Grid.Column="0"
                               Text="0 stacks"
                               FontSize="11"
                               Foreground="#000000"
                               VerticalAlignment="Center"
                               FontFamily="Geneva, Helvetica, Arial, sans-serif"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="CancelButton" Content="Cancel"
                                Classes="sys7"
                                Width="80" Height="24"
                                Click="OnCancelClick" IsCancel="True"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                FontSize="12"/>
                        <Border BorderBrush="#000000" BorderThickness="3" CornerRadius="4" Padding="0">
                            <Button x:Name="OkButton" Content="Open"
                                    Classes="sys7"
                                    Width="76" Height="20"
                                    Click="OnOkClick" IsDefault="True"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontWeight="Bold" CornerRadius="3"
                                    FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Column headers (Finder-style) -->
                <Border DockPanel.Dock="Top"
                        Background="#FFFFFF"
                        BorderBrush="#000000" BorderThickness="1,1,1,1"
                        Padding="0" Height="18">
                    <Grid ColumnDefinitions="*,52,60,76">
                        <TextBlock Grid.Column="0" Text="Name"
                                   FontWeight="Bold" FontSize="10"
                                   Foreground="#000000"
                                   FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                        <Border Grid.Column="1" BorderBrush="#000000" BorderThickness="1,0,0,0">
                            <TextBlock Text="Cards"
                                       FontWeight="Bold" FontSize="10"
                                       Foreground="#000000"
                                       FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="#000000" BorderThickness="1,0,0,0">
                            <TextBlock Text="Size"
                                       FontWeight="Bold" FontSize="10"
                                       Foreground="#000000"
                                       FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                        </Border>
                        <Border Grid.Column="3" BorderBrush="#000000" BorderThickness="1,0,0,0">
                            <TextBlock Text="Resolution"
                                       FontWeight="Bold" FontSize="10"
                                       Foreground="#000000"
                                       FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- List area — simple 1px black border (B&W, no gray bevels) -->
                <Border BorderBrush="#000000" BorderThickness="1,0,1,1" Background="#FFFFFF">
                    <ListBox x:Name="StackList"
                             Classes="sys7"
                             Background="#FFFFFF"
                             Foreground="#000000"
                             SelectionMode="Single"
                             BorderThickness="0"
                             Padding="0"
                             FontFamily="Geneva, Helvetica, Arial, sans-serif"
                             FontSize="11">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,52,60,76" Height="18">
                                    <!-- Stack icon + name -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="4,0,0,0">
                                        <!-- HyperCard stack icon: two offset document shapes with dog-eared
                                             corners. Strokes bind to ListBoxItem.Foreground so they
                                             automatically invert (white-on-black) when the row is selected. -->
                                        <Canvas Width="14" Height="16"
                                                VerticalAlignment="Center" Margin="0,0,4,0">
                                            <!-- Back card body -->
                                            <Path Data="M 3,2 L 10,2 L 13,4 L 13,15 L 3,15 Z"
                                                  Stroke="{Binding $parent[ListBoxItem].Foreground}"
                                                  StrokeThickness="1" Fill="Transparent"/>
                                            <!-- Back card dog-ear -->
                                            <Path Data="M 10,2 L 13,4 L 10,4 Z"
                                                  Stroke="{Binding $parent[ListBoxItem].Foreground}"
                                                  StrokeThickness="1"
                                                  Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                            <!-- Front card body (white fill occludes back card strokes
                                                 in the overlap area, just like a real stack of cards) -->
                                            <Path Data="M 0,0 L 7,0 L 10,3 L 10,13 L 0,13 Z"
                                                  Stroke="{Binding $parent[ListBoxItem].Foreground}"
                                                  StrokeThickness="1" Fill="White"/>
                                            <!-- Front card dog-ear -->
                                            <Path Data="M 7,0 L 10,3 L 7,3 Z"
                                                  Stroke="{Binding $parent[ListBoxItem].Foreground}"
                                                  StrokeThickness="1"
                                                  Fill="{Binding $parent[ListBoxItem].Foreground}"/>
                                        </Canvas>
                                        <TextBlock Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CardCount}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                               FontSize="11"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SizeText}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                               FontSize="11"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Resolution}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                               FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

            </DockPanel>
        </DockPanel>
    </Border>
</Window>
