<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.StackPickerWindow"
        Title="Select a Stack"
        Width="480" Height="340"
        MinWidth="400" MinHeight="280"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner"
        Background="#C0C0C0"
        FontFamily="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"
        FontSize="12">

    <!-- 1px black outer border — System 7 window outline -->
    <Border BorderBrush="#000000" BorderThickness="1" Background="#C0C0C0">
        <DockPanel>

            <!-- System 7.5 striped title bar -->
            <controls:System7TitleBar DockPanel.Dock="Top"
                                      Title="Select a Stack"
                                      CloseRequested="OnTitleBarClose"/>

            <!-- Hairline rule under title bar -->
            <Border DockPanel.Dock="Top" Height="1" Background="#000000"/>

            <!-- Content area: 2-column layout like System 7 file dialog -->
            <Grid Margin="12,10,12,12" ColumnDefinitions="*,Auto" RowDefinitions="Auto,*">

                <!-- Prompt label spanning both columns -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="Select a stack to open:"
                           FontSize="12"
                           Foreground="#000000"
                           Margin="0,0,0,6"/>

                <!-- Left column: beveled list box -->
                <Border Grid.Row="1" Grid.Column="0"
                        Margin="0,0,12,0"
                        BorderBrush="#808080" BorderThickness="1,1,0,0">
                <Border BorderBrush="#DFDFDF" BorderThickness="0,0,1,1">
                <Border BorderBrush="#000000" BorderThickness="1,1,0,0">
                <Border BorderBrush="#FFFFFF" BorderThickness="0,0,1,1" Background="#FFFFFF">
                    <ListBox x:Name="StackList"
                             Classes="sys7"
                             Background="#FFFFFF"
                             Foreground="#000000"
                             SelectionMode="Single"
                             FontFamily="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"
                             FontSize="12"/>
                </Border>
                </Border>
                </Border>
                </Border>

                <!-- Right column: buttons stacked vertically (System 7 file dialog layout) -->
                <StackPanel Grid.Row="1" Grid.Column="1"
                            VerticalAlignment="Top" Spacing="8"
                            Width="100">
                    <!-- Default button: 3px outer border = System 7 default-button indicator -->
                    <Border BorderBrush="#000000" BorderThickness="3" CornerRadius="4" Padding="0">
                        <Button x:Name="OkButton" Content="Open"
                                Classes="sys7"
                                Height="26"
                                Click="OnOkClick" IsDefault="True"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                FontWeight="Bold" CornerRadius="3"
                                FontSize="12"/>
                    </Border>
                    <Button x:Name="CancelButton" Content="Cancel"
                            Classes="sys7"
                            Height="26"
                            Click="OnCancelClick" IsCancel="True"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            FontSize="12"/>
                </StackPanel>

            </Grid>
        </DockPanel>
    </Border>
</Window>
