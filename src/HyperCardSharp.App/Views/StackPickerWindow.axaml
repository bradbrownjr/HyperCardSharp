<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.StackPickerWindow"
        Title="Select a Stack"
        Width="480" Height="340"
        MinWidth="400" MinHeight="260"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"
        FontSize="12">

    <!-- System 7 window: 1px black outline, white background -->
    <Border BorderBrush="#000000" BorderThickness="1" Background="#FFFFFF">
        <DockPanel>

            <!-- Striped title bar -->
            <controls:System7TitleBar x:Name="TitleBar"
                                      DockPanel.Dock="Top"
                                      Title="Select a Stack"
                                      CloseRequested="OnTitleBarClose"/>

            <!-- Hairline rule under title bar -->
            <Border DockPanel.Dock="Top" Height="1" Background="#000000"/>

            <!-- Content area -->
            <DockPanel Margin="6,4,6,6">

                <!-- Info line + buttons across the top -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                    <TextBlock x:Name="InfoText" Grid.Column="0"
                               Text="0 stacks"
                               FontSize="10"
                               Foreground="#000000"
                               VerticalAlignment="Center"
                               FontFamily="Geneva, Helvetica, Arial, sans-serif"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <Button x:Name="CancelButton" Content="Cancel"
                                Classes="sys7"
                                Width="80" Height="24"
                                Click="OnCancelClick" IsCancel="True"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                FontSize="12"/>
                        <Border BorderBrush="#000000" BorderThickness="3" CornerRadius="4" Padding="0">
                            <Button x:Name="OkButton" Content="Open"
                                    Classes="sys7"
                                    Width="76" Height="20"
                                    Click="OnOkClick" IsDefault="True"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontWeight="Bold" CornerRadius="3"
                                    FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Column headers (Finder-style) — span full width
                     including the 16px scrollbar column, matching real Finder. -->
                <Border DockPanel.Dock="Top"
                        Background="#FFFFFF"
                        BorderBrush="#000000" BorderThickness="1,1,1,1"
                        Padding="0" Height="16">
                    <Grid ColumnDefinitions="*,52,60,76">
                        <TextBlock Grid.Column="0" Text="Name"
                                   FontSize="10"
                                   Foreground="#000000"
                                   FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>
                        <Border Grid.Column="1" BorderBrush="#000000" BorderThickness="1,0,0,0">
                            <TextBlock Text="Cards"
                                       FontSize="10"
                                       Foreground="#000000"
                                       FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="#000000" BorderThickness="1,0,0,0">
                            <TextBlock Text="Size"
                                       FontSize="10"
                                       Foreground="#000000"
                                       FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                        </Border>
                        <Border Grid.Column="3" BorderBrush="#000000" BorderThickness="1,0,0,0">
                            <TextBlock Text="Resolution"
                                       FontSize="10"
                                       Foreground="#000000"
                                       FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- List + scrollbar + grow-box assembly.
                     Row 0: list content + scrollbar.
                     Row 1: bottom border strip + grow box (16×16 blank square). -->
                <Grid ColumnDefinitions="*,16" RowDefinitions="*,16">

                    <!-- List area — no right border (scrollbar provides it),
                         no bottom border (grow-box row provides it). -->
                    <Border Grid.Column="0" Grid.Row="0"
                            BorderBrush="#000000" BorderThickness="1,0,0,0" Background="#FFFFFF">
                        <ListBox x:Name="StackList"
                                 Classes="sys7"
                                 Background="#FFFFFF"
                                 Foreground="#000000"
                                 SelectionMode="Single"
                                 BorderThickness="0"
                                 Padding="0"
                                 FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                 FontSize="11"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,52,60,76" Height="16">
                                    <!-- Stack icon + name -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="2,0,0,0">
                                        <!-- HyperCard stack icon: three plain cards stacked with 2px
                                             x/y offsets, viewed straight-on (System 7 list-view style).
                                             No dog-ears — too small. Front card white fill occludes cards
                                             behind it. All strokes bind to Foreground so selection inverts. -->
                                        <Canvas Width="13" Height="13"
                                                VerticalAlignment="Center" Margin="0,0,3,0">
                                            <!-- Card 3 — bottommost -->
                                            <Path Data="M 4,4 H 13 V 13 H 4 Z"
                                                  Stroke="{Binding $parent[ListBoxItem].Foreground}"
                                                  StrokeThickness="1" Fill="Transparent"/>
                                            <!-- Card 2 — middle -->
                                            <Path Data="M 2,2 H 11 V 11 H 2 Z"
                                                  Stroke="{Binding $parent[ListBoxItem].Foreground}"
                                                  StrokeThickness="1" Fill="Transparent"/>
                                            <!-- Card 1 — front. White fill occludes cards behind,
                                                 giving depth. On selection it shows as a white card
                                                 on the black highlight bar — authentic Mac behaviour. -->
                                            <Path Data="M 0,0 H 9 V 9 H 0 Z"
                                                  Stroke="{Binding $parent[ListBoxItem].Foreground}"
                                                  StrokeThickness="1" Fill="White"/>
                                        </Canvas>
                                        <TextBlock Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                                   FontSize="10"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CardCount}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                               FontSize="10"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SizeText}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                               FontSize="10"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Resolution}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0"
                                               FontFamily="Geneva, Helvetica, Arial, sans-serif"
                                               FontSize="10"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </Border>

                    <!-- Authentic System 7 scrollbar — beside list only (below headers) -->
                    <controls:System7ScrollBar Grid.Column="1" Grid.Row="0" x:Name="ListScrollBar"/>

                    <!-- Bottom border under list (left of grow box) -->
                    <Border Grid.Column="0" Grid.Row="1"
                            BorderBrush="#000000" BorderThickness="1,1,0,1"
                            Background="#FFFFFF"/>

                    <!-- Grow box: 16×16 blank square at the intersection of
                         scrollbar bottom and list-area bottom-right corner.
                         System 7 always showed this even in non-resizable lists. -->
                    <Border Grid.Column="1" Grid.Row="1"
                            BorderBrush="#000000" BorderThickness="1"
                            Background="#FFFFFF"/>
                </Grid>

            </DockPanel>
        </DockPanel>
    </Border>
</Window>
