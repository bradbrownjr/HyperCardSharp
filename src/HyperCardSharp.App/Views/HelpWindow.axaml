<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HyperCardSharp.App.Controls"
        x:Class="HyperCardSharp.App.Views.HelpWindow"
        Title="HyperCardSharp Help"
        Width="400" Height="450"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        FontFamily="Geneva, Helvetica, Arial, sans-serif"
        FontSize="12">

    <!-- 1px black outer border — System 7 window outline -->
    <Border BorderBrush="#000000" BorderThickness="1" Background="#FFFFFF">
        <DockPanel>

            <!-- System 7.5 striped title bar -->
            <controls:System7TitleBar x:Name="TitleBar"
                                      DockPanel.Dock="Top"
                                      Title="HyperCardSharp Help"
                                      CloseRequested="OnTitleBarClose"/>

            <!-- Content area -->
            <DockPanel Margin="14">

                <!-- Dialog heading -->
                <TextBlock DockPanel.Dock="Top"
                           Text="HyperCardSharp — Keyboard Shortcuts"
                           FontWeight="Bold" FontSize="13"
                           Foreground="#000000"
                           Margin="0,8,0,6"/>

                <!-- Hairline rule below heading -->
                <Border DockPanel.Dock="Top" Height="1" Background="#000000" Margin="0,0,0,10"/>

                <!-- OK button at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Border BorderBrush="#000000" BorderThickness="3" CornerRadius="4" Padding="0">
                        <Button x:Name="OkButton" Content="OK"
                                Classes="sys7"
                                Width="84" Height="20"
                                Click="OnOkClick" IsDefault="True"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                FontWeight="Bold" CornerRadius="3"
                                FontSize="12"/>
                    </Border>
                </StackPanel>

                <!-- macOS note -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="On macOS, use ⌘ (Command) instead of Ctrl."
                           FontSize="11" Foreground="#000000"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>

                <!-- Divider above macOS note -->
                <Border DockPanel.Dock="Bottom" Height="1" Background="#000000" Margin="0,8,0,0"/>

                <!-- Scrollable shortcut list -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10" Margin="0,0,0,4">

                        <!-- ── Navigation ── -->
                        <TextBlock Text="Navigation" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                        <Grid Margin="10,0,0,0" ColumnDefinitions="155,*"
                              RowDefinitions="Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="← ↑"         Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Previous card" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="→ ↓  Space"   Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Next card"    Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Home"         Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="First card"   Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="End"          Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Last card"    Margin="0,2"/>
                        </Grid>

                        <!-- ── Zoom ── -->
                        <TextBlock Text="Zoom" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                        <Grid Margin="10,0,0,0" ColumnDefinitions="155,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+1"  Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="100%  (512 × 342)" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+2"  Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="150%"    Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+3"  Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="200%"    Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+4"  Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="400%"    Margin="0,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+="  Margin="0,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Zoom in one step"  Margin="0,2"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Ctrl+−"  Margin="0,2"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="Zoom out one step" Margin="0,2"/>
                        </Grid>

                        <!-- ── File &amp; Stacks ── -->
                        <TextBlock Text="File &amp; Stacks" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                        <Grid Margin="10,0,0,0" ColumnDefinitions="155,*"
                              RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+O" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Open file…"   Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+M" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Stack list…"  Margin="0,2"/>
                        </Grid>

                        <!-- ── Help ── -->
                        <TextBlock Text="Help" FontWeight="Bold" FontSize="12" Foreground="#000000"/>
                        <Grid Margin="10,0,0,0" ColumnDefinitions="155,*"
                              RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="F1  / Ctrl+H" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Show this window" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="⌘? (classic Mac)" Margin="0,2" FontSize="11" Foreground="#000000"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="HyperCard help (historical)" Margin="0,2" FontSize="11" Foreground="#000000"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </DockPanel>
    </Border>
</Window>
