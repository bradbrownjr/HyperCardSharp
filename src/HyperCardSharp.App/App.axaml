<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HyperCardSharp.App.App">

    <!-- Override Fluent theme resource keys for menus — this is the ONLY way
         to change the popup background since Fluent binds via DynamicResource. -->
    <Application.Resources>
        <!-- Menu flyout (dropdown popup) -->
        <SolidColorBrush x:Key="MenuFlyoutPresenterBackground"        Color="White"/>
        <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush"       Color="Black"/>
        <Thickness        x:Key="MenuFlyoutPresenterBorderThemeThickness">1</Thickness>
        <CornerRadius     x:Key="OverlayCornerRadius">0</CornerRadius>

        <!-- Menu flyout items — normal state -->
        <SolidColorBrush x:Key="MenuFlyoutItemBackground"             Color="White"/>
        <SolidColorBrush x:Key="MenuFlyoutItemForeground"             Color="Black"/>
        <!-- Menu flyout items — hover: black highlight, white text (System 7) -->
        <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver"  Color="Black"/>
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver"  Color="White"/>
        <!-- Menu flyout items — pressed -->
        <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPressed"      Color="Black"/>
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed"      Color="White"/>
        <!-- Menu flyout items — disabled -->
        <!-- Disabled menu text: #808080 approximates the 1-bit dither pattern
             real Macs used. A SolidColorBrush cannot replicate the checkerboard,
             so gray is the closest visual equivalent for disabled state. -->
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundDisabled"     Color="#808080"/>

        <!-- Top-level menu bar items -->
        <SolidColorBrush x:Key="MenuBarItemBackground"                Color="Transparent"/>
        <SolidColorBrush x:Key="MenuBarItemBackgroundPointerOver"     Color="Black"/>
        <SolidColorBrush x:Key="MenuBarItemBackgroundSelected"        Color="Black"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- ══════════════════════════════════════════════════════════════
             System 7 Menu — style overrides (font, weight, colors)
             Resource keys above handle the popup bg; styles here handle
             font family, weight, and text color on state changes.
             ══════════════════════════════════════════════════════════════ -->

        <!-- Top-level menu bar items: bold Chicago, black text -->
        <Style Selector="Menu > MenuItem">
            <Setter Property="Foreground"   Value="#000000"/>
            <Setter Property="FontFamily"   Value="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Padding"      Value="5,2"/>
        </Style>
        <Style Selector="Menu > MenuItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#000000"/>
            <Setter Property="TextBlock.FontWeight" Value="Bold"/>
        </Style>
        <!-- Hover / open: white text on black bg (resource handles bg) -->
        <Style Selector="Menu > MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Menu > MenuItem:pressed /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Menu > MenuItem:open /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Dropdown menu items: Chicago font, normal weight, black text -->
        <Style Selector="MenuItem">
            <Setter Property="Foreground"   Value="#000000"/>
            <Setter Property="FontFamily"   Value="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="8,3"/>
        </Style>
        <Style Selector="MenuItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#000000"/>
        </Style>
        <Style Selector="MenuItem /template/ ContentPresenter#PART_InputGesturePresenter">
            <Setter Property="TextBlock.Foreground" Value="#000000"/>
        </Style>
        <!-- Hover: white text (bg handled by resource) -->
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_InputGesturePresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Separator: thin black line (B&W — no gray) -->
        <Style Selector="MenuItem > Separator">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0"/>
        </Style>

        <!-- ── System 7 button style (B&W — no gray) ─────────────────────
             Apply Classes="sys7" to any Button inside a System 7 dialog.
             Suppresses Fluent hover glow; flat white with black/white
             inversion on press (authentic 1-bit Mac feel).
        -->
        <Style Selector="Button.sys7">
            <Setter Property="Background"   Value="#FFFFFF"/>
            <Setter Property="Foreground"   Value="#000000"/>
            <Setter Property="BorderBrush"  Value="#000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding"      Value="0"/>
        </Style>
        <Style Selector="Button.sys7 /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"              Value="#FFFFFF"/>
            <Setter Property="TextElement.Foreground"  Value="#000000"/>
            <Setter Property="CornerRadius"            Value="4"/>
        </Style>
        <Style Selector="Button.sys7:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"              Value="#FFFFFF"/>
            <Setter Property="TextElement.Foreground"  Value="#000000"/>
        </Style>
        <Style Selector="Button.sys7:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"              Value="#000000"/>
            <Setter Property="TextElement.Foreground"  Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.sys7:pressed">
            <Setter Property="Foreground"   Value="#FFFFFF"/>
        </Style>
        <!-- Remove Fluent focus ring -->
        <Style Selector="Button.sys7:focus-visible /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"              Value="#FFFFFF"/>
            <Setter Property="TextElement.Foreground"  Value="#000000"/>
        </Style>

        <!-- ── System 7.5 ListBox selection highlight ───────────────────
             Solid black selection bar with white text — authentic System 7.
        -->
        <Style Selector="ListBox.sys7 ListBoxItem">
            <Setter Property="Foreground"   Value="#000000"/>
            <Setter Property="FontFamily"   Value="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="6,3"/>
        </Style>
        <Style Selector="ListBox.sys7 ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background"             Value="#000000"/>
            <Setter Property="TextElement.Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="ListBox.sys7 ListBoxItem:selected">
            <Setter Property="Foreground"   Value="#FFFFFF"/>
        </Style>
        <Style Selector="ListBox.sys7 ListBoxItem:not(:selected):pointerover /template/ ContentPresenter">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="#000000"/>
        </Style>
        <!-- Keep text black on hover — Fluent theme's default hover state can
             change foreground to white, making text invisible on a white background. -->
        <Style Selector="ListBox.sys7 ListBoxItem:not(:selected):pointerover">
            <Setter Property="Foreground"   Value="#000000"/>
        </Style>
    </Application.Styles>
</Application>
