<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HyperCardSharp.App.App">
    <Application.Styles>
        <FluentTheme />

        <!-- ══════════════════════════════════════════════════════════════
             System 7 Menu Bar — override Fluent theme completely
             ══════════════════════════════════════════════════════════════ -->

        <!-- Top-level menu bar items: black text, transparent bg -->
        <Style Selector="Menu > MenuItem">
            <Setter Property="Foreground"   Value="#000000"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="FontFamily"   Value="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="Padding"      Value="6,2"/>
        </Style>
        <Style Selector="Menu > MenuItem /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"   Value="Transparent"/>
        </Style>
        <Style Selector="Menu > MenuItem /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#000000"/>
        </Style>
        <Style Selector="Menu > MenuItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"   Value="#000000"/>
        </Style>
        <Style Selector="Menu > MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Menu > MenuItem:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"   Value="#000000"/>
        </Style>
        <Style Selector="Menu > MenuItem:pressed /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>
        <!-- While submenu is open, keep top-level item highlighted -->
        <Style Selector="Menu > MenuItem:open /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"   Value="#000000"/>
        </Style>
        <Style Selector="Menu > MenuItem:open /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Dropdown popup container: white bg, black 1px border, no rounded corners -->
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background"       Value="#FFFFFF"/>
            <Setter Property="BorderBrush"       Value="#000000"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="CornerRadius"      Value="0"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Foreground"        Value="#000000"/>
            <Setter Property="FontFamily"        Value="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"/>
            <Setter Property="FontSize"          Value="14"/>
        </Style>
        <!-- Override the Fluent inner template border too -->
        <Style Selector="MenuFlyoutPresenter /template/ Border">
            <Setter Property="Background"       Value="#FFFFFF"/>
            <Setter Property="CornerRadius"      Value="0"/>
        </Style>

        <!-- All dropdown menu items: white bg, black text, Chicago font -->
        <Style Selector="MenuItem">
            <Setter Property="Foreground"   Value="#000000"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="FontFamily"   Value="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="Padding"      Value="8,3"/>
        </Style>
        <Style Selector="MenuItem /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"   Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <!-- Hover: black bar with white text (System 7 highlight) -->
        <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"   Value="#000000"/>
        </Style>
        <Style Selector="MenuItem:pointerover">
            <Setter Property="Foreground"   Value="#FFFFFF"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_InputGesturePresenter">
            <Setter Property="TextBlock.Foreground" Value="#FFFFFF"/>
        </Style>
        <!-- Pressed state -->
        <Style Selector="MenuItem:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"   Value="#000000"/>
        </Style>
        <Style Selector="MenuItem:pressed">
            <Setter Property="Foreground"   Value="#FFFFFF"/>
        </Style>
        <!-- Selected/open state for items with submenus -->
        <Style Selector="MenuItem:open /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"   Value="#000000"/>
        </Style>
        <Style Selector="MenuItem:open">
            <Setter Property="Foreground"   Value="#FFFFFF"/>
        </Style>

        <!-- Separator inside menus: gray line -->
        <Style Selector="MenuItem > Separator">
            <Setter Property="Background"   Value="#808080"/>
            <Setter Property="Height"       Value="1"/>
            <Setter Property="Margin"       Value="0"/>
        </Style>

        <!-- ── System 7.5 button style ──────────────────────────────────
             Apply Classes="sys7" to any Button inside a System 7 dialog.
             Suppresses Fluent hover glow; uses flat gray with subtle darken
             on hover and black/white inversion on press (authentic Mac feel).
        -->
        <Style Selector="Button.sys7">
            <Setter Property="Background"   Value="#DDDDDD"/>
            <Setter Property="Foreground"   Value="#000000"/>
            <Setter Property="BorderBrush"  Value="#000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding"      Value="0"/>
        </Style>
        <Style Selector="Button.sys7 /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"   Value="#DDDDDD"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.sys7:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"   Value="#C8C8C8"/>
        </Style>
        <Style Selector="Button.sys7:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"   Value="#000000"/>
        </Style>
        <Style Selector="Button.sys7:pressed">
            <Setter Property="Foreground"   Value="#FFFFFF"/>
        </Style>
        <!-- Remove Fluent focus ring -->
        <Style Selector="Button.sys7:focus-visible /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background"   Value="#DDDDDD"/>
        </Style>

        <!-- ── System 7.5 ListBox selection highlight ───────────────────
             Solid black selection bar with white text — authentic System 7.
        -->
        <Style Selector="ListBox.sys7 ListBoxItem">
            <Setter Property="Foreground"   Value="#000000"/>
            <Setter Property="FontFamily"   Value="avares://HyperCardSharp.App/Assets/Fonts#ChicagoFLF, Chicago, Geneva, Helvetica, Arial, sans-serif"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="6,3"/>
        </Style>
        <Style Selector="ListBox.sys7 ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background"   Value="#000000"/>
        </Style>
        <Style Selector="ListBox.sys7 ListBoxItem:selected">
            <Setter Property="Foreground"   Value="#FFFFFF"/>
        </Style>
        <Style Selector="ListBox.sys7 ListBoxItem:not(:selected):pointerover /template/ ContentPresenter">
            <Setter Property="Background"   Value="#C8C8C8"/>
        </Style>
    </Application.Styles>
</Application>
